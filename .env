# Non-secret runtime configuration for local runs / act.
# Copy or edit these values for your local Anthropic-compatible setup.

# Model/provider settings
LLM_PROVIDER=anthropic
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_MODEL=glm-4.7

# # Some tools also accept these mirrored names when using an Anthropic-compatible gateway
# MODEL_PROVIDER=anthropic
# MODEL_BASE_URL=https://api.anthropic.com
# MODEL_NAME=claude-3-5-sonnet-latest

# Optional eval tuning
ANTHROPIC_TEMPERATURE=0
